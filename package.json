{
  "name": "canvas-editor-pdf",
  "author": "Douglas",
  "license": "MIT",
  "version": "0.4.0",
  "description": "pdf exporter to canvas-editor",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "types": "./dist/types/index.d.ts",
  "main": "./dist/canvas-editor-pdf.umd.js",
  "module": "./dist/canvas-editor-pdf.es.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/canvas-editor-pdf.es.js",
      "require": "./dist/canvas-editor-pdf.umd.js"
    },
    "./node": {
      "types": "./dist/types/node.d.ts",
      "import": "./dist/node/index.es.js",
      "require": "./dist/node/index.cjs.js"
    },
    "./font/*": "./dist/font/*"
  },
  "homepage": "https://github.com/douglasmatheus/canvas-editor-pdf",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/douglasmatheus/canvas-editor-pdf.git"
  },
  "keywords": [
    "canvas-editor",
    "pdf-exporter"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite build --mode lib-browser --watch",
    "build": "npm run lint && npm run build:browser && npm run build:node:esm && npm run build:node:cjs && npm run build:types",
    "build:browser": "vite build --mode lib-browser",
    "build:node:esm": "vite build --mode lib-node",
    "build:node:cjs": "vite build --mode lib-node-cjs",
    "build:types": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "type:check": ""
  },
  "peerDependencies": {
    "@hufe921/canvas-editor": "^0.9.133",
    "@napi-rs/canvas": "^0.1.0",
    "@resvg/resvg-js": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@napi-rs/canvas": {
      "optional": true
    },
    "@resvg/resvg-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hufe921/canvas-editor": "^0.9.134",
    "@napi-rs/canvas": "^0.1.0",
    "@resvg/resvg-js": "^2.0.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "16.18.96",
    "@types/prismjs": "^1.26.0",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "cypress": "13.6.0",
    "cypress-file-upload": "^5.0.8",
    "eslint": "^7.32.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.8.1",
    "vite": "^5.4.21",
    "vite-plugin-css-injected-by-js": "^3.5.2"
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "prismjs": "^1.30.0"
  }
}
